# ============================================================
# 养基日记 — 环境变量配置模板
# ============================================================
# 使用方法:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的真实配置值
#   3. ⚠️ .env 绝不要提交到 Git！已在 .gitignore 中排除
# ============================================================

# ─── QQ 邮箱 SMTP（发送分析报告）───
# 发送方邮箱地址（推荐 QQ 邮箱）
SMTP_USER=your_qq_email@qq.com
# QQ 邮箱 SMTP 授权码（不是 QQ 密码！在 QQ 邮箱 → 设置 → 账户 → POP3/SMTP 服务 获取）
SMTP_PASS=your_qq_smtp_authorization_code
# 接收分析报告的邮箱地址
SMTP_TO=recipient@qq.com

# ─── 养基宝 API（支付宝基金持仓数据）───
# API Secret（可选，代码已内置默认值，一般不用改）
# YJB_API_SECRET=
# 账户 ID（可选，默认自动获取第一个账户）
# YJB_ACCOUNT_ID=

# ─── DeepSeek API（AI 投资解读）───
# DeepSeek API Key → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key
# 模型选择: deepseek-chat (推荐) 或 deepseek-reasoner
LLM_MODEL=deepseek-chat

# ─── VPS SSH（仅 check-deepseek.py 远程诊断用，可选）───
VPS_HOST=your_vps_ip
VPS_USER=root
VPS_PASS=your_vps_password

# ─── Web 看板 ──
# Web 看板的访问地址（邮件中会附带此链接）
# 本地运行: http://localhost:3848
# VPS 部署: http://你的VPS_IP:3848
DASHBOARD_URL=http://localhost:3848

# ─── 可选配置 ──
# 日志级别: trace | debug | info | warn | error
LOG_LEVEL=info
# Node.js 环境: development | production
NODE_ENV=development
