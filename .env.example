# ============================================================
# 养基日记 — 环境变量配置模板
# ============================================================
# 使用方法:
#   1. 复制:  cp .env.example .env
#   2. 只填你需要用到的变量，不需要的保持注释状态
#   3. ⚠️ .env 绝不要提交到 Git！已在 .gitignore 中排除
# ============================================================
#
#  必填 / 可选一览：
#  ┌──────────────────────┬──────────┬─────────────────────┐
#  │ 变量                 │ 必要性    │ 不填的影响           │
#  ├──────────────────────┼──────────┼─────────────────────┤
#  │ 养基宝 扫码登录       │ 必做      │ 拿不到持仓数据       │
#  │ DEEPSEEK_API_KEY     │ 可选      │ 没有 AI 解读段       │
#  │ SMTP_USER/PASS/TO    │ 可选      │ 不发邮件，终端照样出  │
#  │ YJB_API_SECRET       │ 可选      │ 代码已内置默认值     │
#  │ YJB_ACCOUNT_ID       │ 可选      │ 自动取第一个账户     │
#  │ 其他                 │ 全可选    │ —                   │
#  └──────────────────────┴──────────┴─────────────────────┘
# ============================================================

# ─── QQ 邮箱 SMTP（可选，需要发邮件报告时才填）───
# QQ 邮箱地址
SMTP_USER=your_qq_email@qq.com
# QQ 邮箱授权码（不是 QQ 密码！获取路径：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 生成授权码）
SMTP_PASS=your_qq_smtp_authorization_code
# 接收报告的邮箱
SMTP_TO=recipient@qq.com

# ─── 养基宝 API（支付宝基金持仓）───
# ⬇️ 以下两项都不需要填，代码已内置默认值，扫码登录就能用
# YJB_API_SECRET=
# YJB_ACCOUNT_ID=

# ─── DeepSeek API（可选，需要 AI 投资解读时才填）───
# 注册即送额度 → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key
# 模型: deepseek-chat（推荐）或 deepseek-reasoner
LLM_MODEL=deepseek-chat

# ─── VPS SSH（仅 check-deepseek.py 远程诊断用，可选）───
# VPS_HOST=your_vps_ip
# VPS_USER=root
# VPS_PASS=your_vps_password

# ─── Web 看板（可选）───
DASHBOARD_URL=http://localhost:3848

# ─── 其他可选配置 ──
LOG_LEVEL=info
NODE_ENV=development
